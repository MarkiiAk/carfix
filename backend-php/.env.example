# Configuración de Base de Datos para Producción - CarFix
# Copiar este archivo como .env y configurar con los valores reales del servidor

# Host de la base de datos (generalmente localhost en cPanel)
DB_HOST=localhost

# Nombre de la base de datos (proporcionado por cPanel)
DB_NAME=carfix_produccion

# Usuario de la base de datos (proporcionado por cPanel)
DB_USER=tu_usuario_mysql

# Contraseña de la base de datos (proporcionada por cPanel)
DB_PASS=tu_password_mysql

# Configuración JWT (opcional)
JWT_SECRET=tu_jwt_secret_key_super_segura

# Configuración WhatsApp (opcional)
WHATSAPP_TOKEN=tu_whatsapp_token
WHATSAPP_PHONE_ID=tu_phone_id